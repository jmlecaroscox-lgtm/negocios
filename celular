    <td class="td-mono" style="text-align:right">${fmt(fl.reduce((a,p)=>a+(Number(p.kg_guia)||0),0))}</td>
    <td class="td-mono" style="text-align:right;color:var(--green)">${fmt(fl.reduce((a,p)=>a+(Number(p.kg_real)||0),0))||'—'}</td>
